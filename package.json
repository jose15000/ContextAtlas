{
  "name": "@contextatlas/core",
  "version": "1.0.60",
  "type": "module",
  "description": "ContextAtlas context graph database and MCP server",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "mcp-atlas": "./dist/mcp/server.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test",
    "dev": "bun run --watch src/index.ts",
    "mcp": "tsc -p tsconfig.build.json && chmod 755 dist/mcp/server.js",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/mcp/server.js dist/ui.js && node dist/scripts/copyAgents.js",
    "prepublishOnly": "npm run build",
    "postinstall": "node dist/scripts/postinstall.js"
  },
  "author": "Jose",
  "license": "MIT",
  "dependencies": {
    "@elysiajs/node": "^1.4.5",
    "@elysiajs/static": "^1.4.7",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xenova/transformers": "^2.17.2",
    "@xyflow/react": "^12.10.2",
    "chokidar": "^5.0.0",
    "elysia": "latest",
    "lucide-react": "^1.7.0",
    "sharp": "^0.34.5",
    "ts-morph": "^27.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "bun-types": "latest",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
