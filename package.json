{
  "name": "@contextatlas/core",
  "version": "1.0.54",
  "type": "module",
  "description": "ContextAtlas context graph database and MCP server",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "bin": {
    "mcp-atlas": "./dist/MCP/server.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test",
    "dev": "bun run --watch src/index.ts",
    "mcp": "tsc -p tsconfig.build.json && chmod 755 dist/MCP/server.js",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/MCP/server.js",
    "prepublishOnly": "npm run build"
  },
  "author": "Jose",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xenova/transformers": "^2.17.2",
    "elysia": "latest",
    "ts-morph": "^27.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "bun-types": "latest",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}